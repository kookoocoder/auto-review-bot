CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Public URL of this Next.js app (QR codes point here)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Placeholder owner id until auth is added
DEMO_OWNER_ID=demo-owner

# CI only — deploy key from Convex dashboard → Settings → Deploy Key
# CONVEX_DEPLOY_KEY=
